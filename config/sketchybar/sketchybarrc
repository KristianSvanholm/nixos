#!/bin/bash
# Gruvbox dark palette
BG=0xff282828
BG1=0xff3c3836
BG2=0xff504945
FG=0xffebdbb2
GRAY=0xff928374
YELLOW=0xffd79921
GREEN=0xff98971a
RED=0xffcc241d
BLUE=0xff458588
FONT="JetBrainsMono Nerd Font"
PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

# Icons (Nerd Font)
ICON_CLOCK=""
ICON_CAL=""
ICON_BAT=""
ICON_BAT_LOW=""
ICON_CHARGING=""

# -- Bar --
sketchybar --bar height=32 color=$BG position=top sticky=on \
  padding_left=8 padding_right=8 topmost=window font_smoothing=on display=all

# -- Defaults --
sketchybar --default \
  icon.font="$FONT:Bold:14.0" icon.color=$FG icon.padding_left=8 icon.padding_right=4 \
  label.font="$FONT:Regular:13.0" label.color=$FG label.padding_left=4 label.padding_right=8 \
  background.color=$BG1 background.corner_radius=5 background.height=24 \
  padding_left=4 padding_right=4

# -- Workspaces --
sketchybar --add event aerospace_workspace_change
for sid in $(aerospace list-workspaces --all); do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid icon="$sid" icon.padding_left=8 icon.padding_right=8 \
      label.drawing=off background.drawing=off background.corner_radius=5 background.height=22 \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/workspace.sh $sid"
done

# Init workspace highlights
FOCUSED=$(aerospace list-workspaces --focused)
VISIBLE=$(aerospace list-workspaces --monitor all --visible)
for vid in $VISIBLE; do
  if [ "$vid" = "$FOCUSED" ]; then
    sketchybar --set "space.$vid" background.drawing=on background.color=$BG2 \
      background.border_width=0 icon.color=$FG
  else
    sketchybar --set "space.$vid" background.drawing=on background.color=0x00000000 \
      background.border_color=$BG2 background.border_width=2 icon.color=$FG
  fi
done

# -- Front app (center) --
sketchybar --add item front_app center \
  --set front_app icon.drawing=off label.font="$FONT:Bold:13.0" background.drawing=off \
    script='sketchybar --set "$NAME" label="$INFO"' \
  --subscribe front_app front_app_switched

# -- Clock --
sketchybar --add item clock right \
  --set clock icon="$ICON_CLOCK" icon.color=$YELLOW icon.y_offset=1 \
    background.drawing=on update_freq=30 \
    script='sketchybar --set "$NAME" label="$(date "+%H:%M")"'

# -- Date --
sketchybar --add item date right \
  --set date icon="$ICON_CAL" icon.color=$BLUE icon.y_offset=1 \
    background.drawing=on update_freq=60 \
    script='sketchybar --set "$NAME" label="$(date "+%a %d %b")"'

# -- Battery --
sketchybar --add item battery right \
  --set battery icon="$ICON_BAT" icon.color=$GREEN icon.y_offset=1 \
    background.drawing=on update_freq=60 \
    script="$PLUGIN_DIR/battery.sh"

sketchybar --update
